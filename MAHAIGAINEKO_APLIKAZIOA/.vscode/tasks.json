{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "javac",
            "args": [
                "-d", "bin",
                "-cp", "lib/junit-platform-console-standalone-1.13.0-M3.jar;lib/gson-2.10.1.jar;lib/mysql-connector-j-9.6.0.jar",
                "src/*.java"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always"
            }
        },
        {
            "label": "Run Tests",
            "type": "shell",
            "command": "java",
            "args": [
                "-jar", "lib/junit-platform-console-standalone-1.13.0-M3.jar",
                "--cp", "bin",
                "--scan-classpath"
            ],
            "dependsOn": ["Build"],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        }
    ]
}
